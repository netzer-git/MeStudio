# MeStudio Agent — Environment Configuration
# Copy this file to .env and adjust values as needed.
# All variables use the MESTUDIO_ prefix.

# LM Studio connection
MESTUDIO_LM_STUDIO_URL=http://localhost:1234/v1
MESTUDIO_LM_STUDIO_MODEL=gpt-oss-20b
MESTUDIO_LM_STUDIO_API_KEY=lm-studio

# Context window
MESTUDIO_MAX_CONTEXT_TOKENS=131072

# Directories
MESTUDIO_WORKING_DIRECTORY=.
MESTUDIO_DATA_DIRECTORY=./data

# Browser / web search
MESTUDIO_BROWSER_HEADLESS=true

# Optional: Brave Search API key for fallback search provider (free tier: 2K queries/month)
# MESTUDIO_BRAVE_SEARCH_API_KEY=

# Logging configuration
MESTUDIO_LOG_LEVEL=INFO
MESTUDIO_LOG_FILE=./data/logs/mestudio.log
MESTUDIO_LOG_MAX_SIZE=50 MB
MESTUDIO_LOG_ROTATION_COUNT=5
MESTUDIO_LOG_JSON_FORMAT=true
